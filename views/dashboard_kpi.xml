<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Eliminar menú viejo del Dashboard KPIs si ya fue instalado -->
    <delete model="ir.ui.menu"
            search="[('name', '=', 'Dashboard KPIs'), ('parent_id', '=', ref('menu_tarifario_root'))]"/>

    <!-- Eliminar menú intermedio Operaciones para dejar acceso directo al catálogo -->
    <delete model="ir.ui.menu"
            search="[('name', '=', 'Operaciones'), ('parent_id', '=', ref('menu_tarifario_root'))]"/>

    <!-- Eliminar acción cliente del dashboard si ya fue instalada -->
    <delete model="ir.actions.client"
            search="[('tag', '=', 'tarifario_dashboard_tag')]"/>
</odoo>